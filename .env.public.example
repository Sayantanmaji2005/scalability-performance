# Copy to .env and replace values before public deployment.
JWT_SECRET=replace-with-a-long-random-base64-secret
APP_CORS_ALLOWED_ORIGINS=https://your-domain.com
VITE_API_BASE=/api/v1
APP_AUTH_EXPOSE_DEBUG_TOKENS=false
APP_SEED_DEMO_USERS=false
APP_MAIL_ENABLED=true
APP_MAIL_FROM=no-reply@your-domain.com
APP_MAIL_BASE_URL=https://your-domain.com
SPRING_MAIL_HOST=smtp.your-provider.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-smtp-username
SPRING_MAIL_PASSWORD=your-smtp-password
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
